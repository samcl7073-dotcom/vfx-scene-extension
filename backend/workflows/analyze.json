      "fill_mask": true,
      "output_mask_select": "",
      "max_new_tokens": 1024,
      "num_beams": 3,
      "keep_model_loaded": true
    }
  },
  "4": {
    "class_type": "Florence2Run",
    "inputs": {
      "model": ["1", 0],
      "image": ["2", 0],
      "text_input": "",
      "task": "object_detection",
      "fill_mask": true,
      "output_mask_select": "",
      "max_new_tokens": 1024,
      "num_beams": 3,
      "keep_model_loaded": true
    }
  }
