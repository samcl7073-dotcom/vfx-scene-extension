{
  "1": {
    "class_type": "DownloadAndLoadFlorence2Model",
    "inputs": {
      "model": "microsoft/Florence-2-base",
      "precision": "fp16",
      "attention": "sdpa"
    }
  },
  "2": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "__IMAGE_FILENAME__"
    }
  },
  "3": {
    "class_type": "Florence2Run",
